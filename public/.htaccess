# ── Panel klienta TwistedPixel — statyczny eksport Next.js na Apache (CyberFolks) ──

# Wymuś HTTPS (działa dopiero gdy certyfikat SSL jest aktywny dla subdomeny)
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{HTTPS} off
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>

# Strona 404 z eksportu Next.js
ErrorDocument 404 /404.html

# Cache: zasoby _next/static mają hash w nazwie → można cache'ować na rok.
# HTML nie cache'ujemy, żeby po nowym wdrożeniu klienci od razu widzieli zmiany.
<IfModule mod_headers.c>
  <FilesMatch "\.(js|css|woff2?|png|jpg|jpeg|gif|svg|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
</IfModule>

# Kompresja
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>
